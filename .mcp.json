{
  "mcpServers": {
    "mcp-youtube": {
      "command": "npx",
      "args": ["-y", "mcp-youtube"]
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "remotion": {
      "command": "npx",
      "args": ["-y", "@remotion/mcp@4.0.467", "--directory", "./remotion-all"]
    }
  }
}
