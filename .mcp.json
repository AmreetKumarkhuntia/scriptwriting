{
  "mcpServers": {
    "google-trends": {
      "command": "npx",
      "args": ["-y", "@den.dance/google-trends-mcp"]
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "remotion": {
      "command": "npx",
      "args": ["-y", "@remotion/mcp@4.0.467", "--directory", "./remotion-all"]
    }
  }
}
